{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Q",
	"scopeName": "source.q",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.q",
					"match": "\\b(if|while|for|return)\\b"
				},
				{
					"name": "keyword.funct",
					"match": "\\b(func)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.q",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.q",
					"match": "\\\\."
				}
			]
		}
	}
}