{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Q",
	"scopeName": "source.q",
	"patterns": [
		{
			"comment": "Keywords",
			"name": "keyword.control.q",
			"match": "\\b(if|ensure|for|loop|mut|require|return)\\b"
		},
		{
			"comment": "Built-in functions",
			"match": "\\b(syscall)\\b",
			"name": "support.function.builtin.q"
		},
		{
			"comment": "Function definitions",
			"match": "^([a-zA-Z0-9]+)\\(",
			"captures": {
				"1": {
					"name": "entity.name.function"
				}
			}
		},
		{
			"name": "meta.definition.import.q",
			"begin": "^\\s*(import)\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.import.q"
				}
			},
			"end": "([0-9a-zA-Z_.]*)",
			"endCaptures": {
				"1": {
					"name": "entity.name.import.q"
				}
			}
		},
		{
			"comment": "Package calls",
			"match": "\\b([a-zA-Z0-9]+)\\.([a-zA-Z0-9]+)\\b",
			"captures": {
				"1": {
					"name": "entity.name.import.q"
				},
				"2": {
					"name": "entity.name.function"
				}
			}
		},
		{
			"comment": "Function calls",
			"match": "\\b([a-zA-Z0-9]+)\\(",
			"captures": {
				"1": {
					"name": "entity.name.function"
				}
			}
		},
		{
			"comment": "Integers",
			"name": "constant.numeric.integer.q",
			"match": "\\b[0-9]+\\b"
		},
		{
			"name": "string.quoted.double.q",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.q",
					"match": "\\\\."
				}
			]
		}
	]
}